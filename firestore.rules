rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isRestaurantOwner(restaurantId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid;
    }

    function isValidRestaurant(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.address is string && data.address.size() > 0 && data.address.size() < 200 &&
             data.ownerUid is string &&
             (!('lastTokenNumber' in data) || (data.lastTokenNumber is int && data.lastTokenNumber >= 0)) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidQueueEntry(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.tokenNumber is int && data.tokenNumber > 0 &&
             data.status in ['waiting', 'called', 'completed'] &&
             (!('customerPhone' in data) || data.customerPhone is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /restaurants/{restaurantId} {
      // Anyone can read restaurant details
      allow get: if true;
      // Owners can list their restaurants
      allow list: if isAuthenticated();
      
      // Only authenticated users can create a restaurant
      allow create: if isAuthenticated() && 
                      request.resource.data.ownerUid == request.auth.uid;
      
      // Allow owner to update everything, OR anyone to increment lastTokenNumber
      allow update: if (isAuthenticated() && resource.data.ownerUid == request.auth.uid) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastTokenNumber']));
      
      // Queue subcollection
      match /queue/{queueId} {
        // Anyone can read queue entries (needed for status check)
        allow read: if true;
        
        // Anyone can join the queue
        allow create: if true;
        
        // Only the restaurant owner can update or delete entries
        allow update, delete: if isRestaurantOwner(restaurantId);
      }
    }
  }
}
